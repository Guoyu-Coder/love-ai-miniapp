/* ── 报告页样式 ── */
.report-actions { margin-top: 16rpx; }
.section-title { font-size: 28rpx; font-weight: 600; margin-bottom: 20rpx; display: block; }

.report-btns { display: flex; gap: 16rpx; }
.report-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  background: #FFF5F7;
  border-radius: var(--radius);
  border: 2rpx solid #FFE0EA;
  font-size: 26rpx;
  color: var(--text-light);
}
.report-btn.active { background: var(--pink-pale); border-color: var(--pink); color: var(--pink-dark); font-weight: 600; }
.btn-icon { font-size: 40rpx; display: block; margin-bottom: 8rpx; }

.section-header { padding: 32rpx 24rpx 12rpx; }
.report-card { margin-bottom: 16rpx; }
.report-card-top { display: flex; justify-content: space-between; margin-bottom: 12rpx; }
.report-type { font-size: 26rpx; font-weight: 600; }
.report-date { font-size: 22rpx; color: var(--text-light); }
.report-stats { display: flex; gap: 16rpx; margin-bottom: 12rpx; }
.report-stat { font-size: 22rpx; color: var(--pink); background: var(--pink-pale); padding: 4rpx 16rpx; border-radius: 16rpx; }
.report-preview { font-size: 26rpx; color: var(--text-light); line-height: 1.6; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 3; overflow: hidden; }
