<!-- ♥ 约会记忆馆 v2.3 -->
<view class="page page-enter">

  <!-- ══ 加载态 ══ -->
  <block wx:if="{{loading}}">
    <view class="hero-skeleton" style="padding:40rpx 24rpx;">
      <view class="skeleton" style="height:240rpx;border-radius:24rpx;margin-bottom:24rpx;"></view>
      <view class="skeleton skeleton-line" style="width:60%;"></view>
      <view class="skeleton skeleton-line"></view>
      <view class="skeleton skeleton-line" style="width:80%;"></view>
    </view>
  </block>

  <!-- ══ 正式内容 ══ -->
  <block wx:else>

    <!-- ── 照片回忆条 ── -->
    <scroll-view class="photo-strip" scroll-x enhanced show-scrollbar="{{false}}" wx:if="{{allPhotos.length > 0}}">
      <view class="photo-strip-inner">
        <image
          wx:for="{{allPhotos}}"
          wx:key="dateId"
          wx:for-item="photo"
          src="{{photo.url}}"
          mode="aspectFill"
          class="strip-photo"
          bindtap="goPhotoDetail"
          data-id="{{photo.dateId}}"
        />
      </view>
    </scroll-view>

    <!-- ── 顶部统计 ── -->
    <view class="stats-card card">
      <view class="stat-block">
        <text class="stat-block-num">{{totalDates}}</text>
        <text class="stat-block-label">次约会</text>
      </view>
      <view class="stat-block-divider"></view>
      <view class="stat-block">
        <text class="stat-block-num">{{totalLocations}}</text>
        <text class="stat-block-label">个地点</text>
      </view>
      <view class="stat-block-divider"></view>
      <view class="stat-block">
        <text class="stat-block-emoji">{{guessEmoji}}</text>
        <text class="stat-block-label">主旋律 · {{favoriteMood}}</text>
      </view>
    </view>

    <!-- ── 视图切换 ── -->
    <view class="view-toggle" wx:if="{{dates.length > 0}}">
      <view class="toggle-tab {{viewMode === 'timeline' ? 'active' : ''}}" bindtap="switchView" data-mode="timeline">
        <text>📋 时间轴</text>
      </view>
      <view class="toggle-tab {{viewMode === 'photo-grid' ? 'active' : ''}}" bindtap="switchView" data-mode="photo-grid" wx:if="{{allPhotos.length > 0}}">
        <text>🖼️ 照片墙</text>
      </view>
    </view>

    <!-- ── 时间轴视图 ── -->
    <view class="timeline" wx:if="{{viewMode === 'timeline' && dates.length > 0}}">
      <block wx:for="{{dates}}" wx:key="_id">
        <view class="tl-item card-stagger" style="animation-delay:{{index * 0.06}}s;">
          <!-- 日期与心情点 -->
          <view class="tl-left">
            <text class="tl-date-text">{{item.date}}</text>
            <view class="tl-dot" style="background:{{moodColors[item.mood] || '#FF7BA6'}};"></view>
            <view class="tl-line"></view>
          </view>
          <!-- 卡片内容 -->
          <view class="tl-card" bindtap="goDetail" data-id="{{item._id}}">
            <!-- 封面图 -->
            <image wx:if="{{item.cover}}" src="{{item.cover}}" mode="aspectFill" class="tl-cover" />

            <view class="tl-card-body">
              <view class="tl-card-top">
                <view class="tl-mood-tag" style="background:{{moodColors[item.mood] || '#FF7BA6'}}1a;color:{{moodColors[item.mood] || '#FF7BA6'}};">
                  {{item.mood || '甜蜜'}}
                </view>
                <text class="tl-location" wx:if="{{item.location}}">📍 {{item.location}}</text>
              </view>
              <text class="tl-activity">{{item.activity}}</text>
              <text class="tl-notes" wx:if="{{item.notes}}">{{item.notes}}</text>

              <!-- 照片缩略 -->
              <view class="tl-thumbs" wx:if="{{item.photos && item.photos.length > 0}}">
                <image
                  wx:for="{{item.photos}}"
                  wx:for-item="thumb"
                  wx:key="*this"
                  src="{{thumb}}"
                  mode="aspectFill"
                  class="tl-thumb"
                  wx:if="{{index < 3}}"
                />
                <view class="tl-thumb-more" wx:if="{{item.photos.length > 3}}">
                  <text>+{{item.photos.length - 3}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </block>
    </view>

    <!-- ── 照片墙视图 ── -->
    <view class="photo-grid" wx:if="{{viewMode === 'photo-grid' && allPhotos.length > 0}}">
      <view class="photo-grid-item" wx:for="{{allPhotos}}" wx:key="dateId" bindtap="goPhotoDetail" data-id="{{item.dateId}}">
        <image src="{{item.url}}" mode="aspectFill" class="grid-photo" />
        <view class="grid-photo-overlay">
          <text class="grid-date">{{item.date}}</text>
        </view>
      </view>
    </view>

    <!-- ── 空状态 ── -->
    <view class="empty-state" wx:if="{{dates.length === 0}}">
      <text class="icon">📸</text>
      <text class="empty-title">还没有约会记录</text>
      <text class="empty-sub">点击下方按钮记录你们的第一次约会吧</text>
      <view class="empty-cta" bindtap="goNewDate">
        <text>💕 开始记录</text>
      </view>
    </view>
  </block>

  <view style="height: 140rpx;"></view>

  <!-- ── FAB ── -->
  <view class="fab" bindtap="goNewDate" wx:if="{{!loading}}">
    <text class="fab-icon">＋</text>
    <text class="fab-text">记录约会</text>
  </view>

  <!-- 回到时间轴顶部 -->
  <view class="scroll-top-btn" wx:if="{{viewMode === 'photo-grid' && allPhotos.length > 12}}" bindtap="switchView" data-mode="timeline">
    <text>📋</text>
  </view>
</view>
