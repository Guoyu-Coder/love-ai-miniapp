/* ── 约会详情样式 ── */

.detail-hero {
  text-align: center;
  padding: 40rpx 0 20rpx;
}
.detail-date { font-size: 32rpx; font-weight: 700; display: block; }
.detail-mood { font-size: 48rpx; margin-top: 8rpx; display: block; }

.detail-row { display: flex; margin-bottom: 20rpx; }
.detail-label { width: 160rpx; font-size: 26rpx; color: var(--text-light); flex-shrink: 0; }
.detail-value { flex: 1; font-size: 28rpx; }
.detail-value.notes { line-height: 1.7; color: var(--text); }

.photo-grid { display: flex; flex-wrap: wrap; gap: 12rpx; padding: 24rpx; }
.detail-photo { width: 210rpx; height: 210rpx; border-radius: 16rpx; }

.ai-analysis { background: linear-gradient(135deg, #FFF0F3, #FFE0EA); border-left: 6rpx solid var(--pink); margin-top: 24rpx; }
.ai-header { margin-bottom: 16rpx; font-size: 26rpx; font-weight: 600; color: var(--pink-dark); }
.ai-content { font-size: 28rpx; line-height: 1.8; color: var(--text); }

/* ── 表单 ── */
.form { margin-bottom: 48rpx; }
.form-group { margin-bottom: 28rpx; }
.form-label { font-size: 26rpx; font-weight: 600; margin-bottom: 12rpx; display: block; }
.form-picker { background: #FFF5F7; border: 2rpx solid #FFE0EA; border-radius: var(--radius); padding: 22rpx 28rpx; font-size: 28rpx; color: var(--text); }

.mood-picker { display: flex; flex-wrap: wrap; gap: 12rpx; }
.mood-item {
  padding: 14rpx 28rpx;
  border-radius: 36rpx;
  background: #FFF5F7;
  border: 2rpx solid #FFE0EA;
  font-size: 26rpx;
  color: var(--text);
}
.mood-item.active { background: var(--pink-pale); border-color: var(--pink); color: var(--pink-dark); font-weight: 600; }

.photo-upload { display: flex; flex-wrap: wrap; gap: 12rpx; }
.upload-preview { width: 140rpx; height: 140rpx; border-radius: 16rpx; }
.upload-btn {
  width: 140rpx; height: 140rpx;
  border: 3rpx dashed #FFE0EA;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFF5F7;
}
.upload-plus { font-size: 56rpx; color: var(--pink-light); font-weight: 300; }

/* ── 地图选点 ── */
.location-row { display: flex; align-items: center; gap: 12rpx; }
.location-picker { flex: 1; }
.gps-btn {
  width: 72rpx; height: 72rpx;
  background: #FFF5F7;
  border: 2rpx solid #FFE0EA;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.gps-btn:active { background: #FFE0EA; }
.gps-icon { font-size: 32rpx; }
.location-detail {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
  padding: 14rpx 20rpx;
  background: #F0FFF0;
  border-radius: 12rpx;
  border: 1rpx solid #B7E4B7;
}
.loc-addr-icon { font-size: 24rpx; }
.loc-addr-text {
  flex: 1;
  font-size: 22rpx;
  color: #2E7D32;
}
.loc-addr-clear {
  font-size: 24rpx;
  color: #999;
  padding: 4rpx 8rpx;
}
