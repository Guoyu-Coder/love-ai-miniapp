/* ── 约会记忆馆 v2.3 ── */

/* ══ 照片回忆条 ══ */
.photo-strip {
  margin: 16rpx 0 8rpx;
  white-space: nowrap;
  padding: 0 0 0 24rpx;
}
.photo-strip-inner {
  display: inline-flex;
  gap: 12rpx;
  padding-right: 24rpx;
}
.strip-photo {
  width: 200rpx;
  height: 240rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  transition: transform 0.2s;
}
.strip-photo:active {
  transform: scale(0.95);
}

/* ══ 统计卡片 ══ */
.stats-card {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 28rpx 16rpx;
  margin-bottom: 0;
  background: linear-gradient(135deg, #FFFFFF, #FFFBFB);
}
.stat-block {
  text-align: center;
  flex: 1;
}
.stat-block-num {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--pink);
  display: block;
  line-height: 1.2;
}
.stat-block-emoji {
  font-size: 40rpx;
  display: block;
  line-height: 1.2;
}
.stat-block-label {
  font-size: 22rpx;
  color: var(--text-light);
  margin-top: 4rpx;
  display: block;
}
.stat-block-divider {
  width: 2rpx;
  height: 48rpx;
  background: #FFE0EA;
  flex-shrink: 0;
}

/* ══ 视图切换 ══ */
.view-toggle {
  display: flex;
  margin: 20rpx 24rpx 12rpx;
  background: #FFF5F7;
  border-radius: 32rpx;
  padding: 6rpx;
  gap: 4rpx;
}
.toggle-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: var(--text-light);
  transition: all 0.25s ease;
}
.toggle-tab.active {
  background: #FFF;
  color: var(--pink-dark);
  font-weight: 600;
  box-shadow: 0 2rpx 12rpx rgba(255,123,166,0.12);
}

/* ══ 时间轴 ══ */
.timeline {
  padding: 0 24rpx;
}
.tl-item {
  display: flex;
  margin-bottom: 6rpx;
}

/* 左侧日期区域 */
.tl-left {
  width: 100rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 6rpx;
}
.tl-date-text {
  font-size: 22rpx;
  color: var(--text-light);
  margin-bottom: 8rpx;
  text-align: center;
  line-height: 1.3;
}
.tl-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  border: 3rpx solid #FFF;
  box-shadow: 0 0 0 3rpx #FFE0EA;
  z-index: 1;
  flex-shrink: 0;
}
.tl-line {
  width: 2rpx;
  flex: 1;
  background: #FFE0EA;
  margin-top: 4rpx;
  min-height: 30rpx;
}

/* 右侧卡片 */
.tl-card {
  flex: 1;
  background: #FFF;
  border-radius: 20rpx;
  margin: 0 0 20rpx 12rpx;
  box-shadow: 0 2rpx 16rpx rgba(255,123,166,0.06);
  overflow: hidden;
  transition: all 0.2s;
}
.tl-card:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 20rpx rgba(255,123,166,0.12);
}

.tl-cover {
  width: 100%;
  height: 280rpx;
}

.tl-card-body {
  padding: 20rpx 24rpx;
}
.tl-card-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}
.tl-mood-tag {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}
.tl-location {
  font-size: 22rpx;
  color: var(--text-light);
}
.tl-activity {
  font-size: 30rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 4rpx;
  color: var(--text);
}
.tl-notes {
  font-size: 24rpx;
  color: var(--text-light);
  display: block;
  line-height: 1.5;
  margin-top: 6rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* 照片缩略 */
.tl-thumbs {
  display: flex;
  gap: 8rpx;
  margin-top: 14rpx;
}
.tl-thumb {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}
.tl-thumb-more {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  background: #FFF0F3;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: var(--pink);
  font-weight: 600;
}

/* ══ 照片墙 ══ */
.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
  padding: 8rpx 24rpx;
}
.photo-grid-item {
  position: relative;
  aspect-ratio: 1;
  border-radius: 16rpx;
  overflow: hidden;
}
.grid-photo {
  width: 100%;
  height: 100%;
}
.grid-photo-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12rpx 16rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.4));
}
.grid-date {
  font-size: 22rpx;
  color: #FFF;
  font-weight: 500;
}

/* ══ 空状态 ══ */
.empty-state {
  padding: 120rpx 0;
}
.empty-title {
  font-size: 28rpx;
  color: var(--text);
  font-weight: 500;
  margin-top: 16rpx;
  display: block;
}
.empty-sub {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 8rpx;
  display: block;
}
.empty-cta {
  margin-top: 32rpx;
  padding: 20rpx 48rpx;
  background: linear-gradient(135deg, #FF7BA6, #FF9AB5);
  border-radius: 48rpx;
  box-shadow: 0 8rpx 28rpx rgba(255,123,166,0.4);
}
.empty-cta text {
  font-size: 28rpx;
  color: #FFF;
  font-weight: 600;
}
.empty-cta:active {
  transform: scale(0.94);
  opacity: 0.9;
}

/* ══ FAB ══ */
.fab {
  position: fixed;
  bottom: 120rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #FF7BA6, #FF9AB5);
  border-radius: 48rpx;
  padding: 20rpx 48rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 28rpx rgba(255,123,166,0.4);
  z-index: 100;
  transition: all 0.2s;
}
.fab:active {
  transform: translateX(-50%) scale(0.94);
  box-shadow: 0 4rpx 16rpx rgba(255,123,166,0.3);
}
.fab-icon {
  font-size: 36rpx;
  color: #FFF;
  font-weight: 700;
}
.fab-text {
  font-size: 28rpx;
  color: #FFF;
  font-weight: 600;
}

/* ══ 滚动回顶按钮 ══ */
.scroll-top-btn {
  position: fixed;
  bottom: 120rpx;
  right: 24rpx;
  width: 72rpx;
  height: 72rpx;
  background: #FFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
  z-index: 99;
  font-size: 32rpx;
}
.scroll-top-btn:active {
  background: #FFF5F7;
  transform: scale(0.9);
}
