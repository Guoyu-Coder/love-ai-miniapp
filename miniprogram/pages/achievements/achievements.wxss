/* ── 成就殿堂 ── */

/* ══ 顶部光环 ══ */
.ach-hero {
  padding: 60rpx 48rpx 40rpx;
  text-align: center;
  background: linear-gradient(180deg, #FFFFFF 0%, #FFFBFB 100%);
}

.ach-hero-ring {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto 28rpx;
  border-radius: 50%;
  background: #FFF0F3;
  display: flex;
  align-items: center;
  justify-content: center;
}
.ach-hero-ring.all-done {
  background: linear-gradient(135deg, #FFD700, #FFA500);
  box-shadow: 0 0 40rpx rgba(255, 215, 0, 0.4);
}

.ach-hero-inner {
  position: relative;
  z-index: 2;
  background: #FFF;
  width: 164rpx;
  height: 164rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.ach-hero-num {
  font-size: 48rpx;
  font-weight: 800;
  color: var(--pink-dark);
  line-height: 1;
}
.ach-hero-total {
  font-size: 28rpx;
  font-weight: 400;
  color: var(--text-light);
}
.ach-hero-label {
  font-size: 22rpx;
  color: var(--text-light);
  margin-top: 4rpx;
}

.ach-hero-sub {
  font-size: 26rpx;
  color: var(--text);
  font-weight: 500;
  line-height: 1.5;
}

/* 环形进度（简化版：用两个半圆模拟） */
.ring-progress {
  position: absolute;
  top: 0; left: 0;
  width: 200rpx; height: 200rpx;
  border-radius: 50%;
  overflow: hidden;
  z-index: 1;
}
.ring-half {
  position: absolute;
  width: 100%; height: 100%;
  clip: rect(0, 200rpx, 200rpx, 100rpx);
}
.ring-half.ring-left {
  clip: rect(0, 100rpx, 200rpx, 0);
}
.ring-fill {
  position: absolute;
  width: 100%; height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF7BA6, #FF9AB5);
  clip: rect(0, 100rpx, 200rpx, 0);
  transform-origin: center center;
  transition: transform 0.8s ease;
}
.ring-done .ring-fill {
  background: linear-gradient(135deg, #FFD700, #FFA500);
}

/* ══ 成就卡片网格 ══ */
.ach-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  padding: 24rpx;
}

.ach-card {
  position: relative;
  background: #FFF;
  border-radius: 24rpx;
  padding: 28rpx 20rpx 24rpx;
  text-align: center;
  box-shadow: 0 2rpx 16rpx rgba(255,123,166,0.06);
  transition: all 0.3s;
  overflow: hidden;
}
.ach-card:active {
  transform: scale(0.96);
}

/* 解锁状态 */
.ach-card.unlocked {
  border: 2rpx solid rgba(255, 123, 166, 0.2);
}
.ach-card-glow {
  position: absolute;
  top: -40rpx; left: 50%;
  transform: translateX(-50%);
  width: 120rpx; height: 60rpx;
  background: radial-gradient(ellipse, rgba(255, 215, 0, 0.25) 0%, transparent 70%);
  pointer-events: none;
}

/* 锁定状态 */
.ach-card.locked {
  opacity: 0.7;
  filter: grayscale(0.3);
}

/* 图标 */
.ach-card-icon-wrap {
  width: 80rpx; height: 80rpx;
  margin: 0 auto 14rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFF0F3, #FFFFFF);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #FFE0EA;
}
.ach-card-icon-wrap.locked-icon {
  background: #F5F5F5;
  border-color: #E0E0E0;
}
.ach-card-icon {
  font-size: 40rpx;
}

/* 名称 */
.ach-card-name {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text);
  display: block;
  margin-bottom: 6rpx;
}
.ach-card.locked .ach-card-name {
  color: var(--text-light);
}

/* 描述 */
.ach-card-desc {
  font-size: 20rpx;
  color: var(--text-light);
  display: block;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

/* 进度条 */
.ach-card-progress {
  padding: 0 8rpx;
}
.ach-card-progress-bar {
  height: 6rpx;
  background: #FFE0EA;
  border-radius: 3rpx;
  overflow: hidden;
  margin-bottom: 6rpx;
}
.ach-card-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF7BA6, #FFB3CC);
  border-radius: 3rpx;
  transition: width 0.6s ease;
}
.ach-card-progress-text {
  font-size: 18rpx;
  color: var(--pink-light);
}

/* 已解锁标记 */
.ach-card-badge {
  margin-top: 12rpx;
}
.ach-card-badge text {
  display: inline-block;
  padding: 4rpx 20rpx;
  background: linear-gradient(135deg, #FFF0F3, #FFFFFF);
  border: 1rpx solid #FFD700;
  border-radius: 20rpx;
  font-size: 20rpx;
  color: #DAA520;
  font-weight: 500;
}

/* ══ 加载态 ══ */
.loading-state {
  padding: 120rpx 48rpx;
}
